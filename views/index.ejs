<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="/styles.css">
    <title>Messages</title>
  </head>
  <body>
    <main>
      <h2>Messages</h2>
      <div>
        <% messages.map((message)=>{%>
          <div class="message">
            <ul>
            <li><%= message.text%></li>
            <li>By: <%=message.user%></li>
            <li>Posted: <%=message.added%></li>
            </ul>
          </div>
        <% }) %>
        </div>
        <a href="./new">Add new message</a>
    </main>
  </body>
</html>
